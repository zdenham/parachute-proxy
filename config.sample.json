{
  "server": {
    "host": "127.0.0.1",
    "port": 3080
  },
  "providers": {
    "anthropic": {
      "enabled": true,
      "apiKey": "sk-ant-api03-YOUR-KEY-HERE"
    },
    "vertex": {
      "enabled": false,
      "region": "us-east5",
      "projectId": "your-gcp-project-id",
      "apiKey": "optional-bearer-token-or-omit-for-ADC"
    },
    "bedrock": {
      "enabled": false,
      "region": "us-east-1",
      "profile": "default"
    }
  },
  "routing": {
    "providerOrder": ["anthropic"]
  },
  "circuitBreaker": {
    "failureThreshold": 5,
    "failureWindowMs": 60000,
    "cooldownMs": 30000
  },
  "retry": {
    "maxRetries": 2,
    "minTimeoutMs": 500,
    "maxTimeoutMs": 5000,
    "requestTimeoutMs": 120000
  }
}
